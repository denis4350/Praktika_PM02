    [vw_RecipeComponentsSum].[RecipeId] AS [RecipeId], 
    [vw_RecipeComponentsSum].[ProductId] AS [ProductId], 
    [vw_RecipeComponentsSum].[ProductName] AS [ProductName], 
    [vw_RecipeComponentsSum].[Version] AS [Version], 
    [vw_RecipeComponentsSum].[Status] AS [Status], 
    [vw_RecipeComponentsSum].[TotalPercentage] AS [TotalPercentage], 
    [vw_RecipeComponentsSum].[ValidationStatus] AS [ValidationStatus]
    FROM [dbo].[vw_RecipeComponentsSum] AS [vw_RecipeComponentsSum]</DefiningQuery>
    </EntitySet>
