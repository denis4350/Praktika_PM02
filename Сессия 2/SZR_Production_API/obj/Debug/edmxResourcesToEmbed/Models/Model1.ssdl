    <EntitySet Name="vw_ActiveBatches" EntityType="Self.vw_ActiveBatches" store:Type="Views" store:Schema="dbo">
      <DefiningQuery>SELECT 
    [vw_ActiveBatches].[BatchNumber] AS [BatchNumber], 
    [vw_ActiveBatches].[ProductName] AS [ProductName], 
    [vw_ActiveBatches].[Line] AS [Line], 
    [vw_ActiveBatches].[Status] AS [Status], 
    [vw_ActiveBatches].[StartedAt] AS [StartedAt]
    FROM [dbo].[vw_ActiveBatches] AS [vw_ActiveBatches]</DefiningQuery>
    </EntitySet>
    <EntitySet Name="vw_RecipeComponentsSum" EntityType="Self.vw_RecipeComponentsSum" store:Type="Views" store:Schema="dbo">
