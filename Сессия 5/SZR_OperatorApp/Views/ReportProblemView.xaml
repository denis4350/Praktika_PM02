<UserControl x:Class="SZR_OperatorApp.Views.ReportProblemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚠" FontSize="24" Margin="0,0,10,0"/>
                <TextBlock Text="Сообщить о проблеме" FontSize="18" FontWeight="Bold" Foreground="White"/>
                <TextBlock Text=" | Оборудование, сырьё, технология" FontSize="13" Foreground="#BDC3C7" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Форма -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,0" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="📝 Форма сообщения о проблеме" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Тип проблемы:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
                <ComboBox x:Name="ProblemTypeBox" Grid.Row="1" Grid.Column="1" Height="35" Margin="5" SelectedIndex="0">
                    <ComboBoxItem Content="Оборудование"/>
                    <ComboBoxItem Content="Сырьё"/>
                    <ComboBoxItem Content="Технология"/>
                    <ComboBoxItem Content="Документация"/>
                    <ComboBoxItem Content="Другое"/>
                </ComboBox>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Партия:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
                <ComboBox x:Name="BatchBox" Grid.Row="2" Grid.Column="1" Height="35" Margin="5"
                          DisplayMemberPath="BatchNumber" SelectedValuePath="BatchNumber"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Оборудование:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
                <ComboBox x:Name="EquipmentBox" Grid.Row="3" Grid.Column="1" Height="35" Margin="5" SelectedIndex="0">
                    <ComboBoxItem Content="Экструдер основной"/>
                    <ComboBoxItem Content="Экструдер резервный"/>
                    <ComboBoxItem Content="Смеситель"/>
                    <ComboBoxItem Content="Охладитель"/>
                    <ComboBoxItem Content="Дозатор"/>
                    <ComboBoxItem Content="Гранулятор"/>
                    <ComboBoxItem Content="Упаковочная машина"/>
                </ComboBox>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Критичность:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
                <ComboBox x:Name="SeverityBox" Grid.Row="4" Grid.Column="1" Height="35" Margin="5" SelectedIndex="0">
                    <ComboBoxItem Content="Информация"/>
                    <ComboBoxItem Content="Предупреждение"/>
                    <ComboBoxItem Content="Критично"/>
                </ComboBox>

                <TextBlock Grid.Row="5" Grid.Column="0" Text="Описание:" FontWeight="Bold" Margin="5" VerticalAlignment="Top"/>
                <TextBox x:Name="DescriptionBox" Grid.Row="5" Grid.Column="1" Height="100" Margin="5" 
                         TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button x:Name="SubmitButton" Content="✉ Отправить сообщение" Width="160" Height="40"
                            Background="#28A745" Foreground="White" FontSize="13" FontWeight="SemiBold"
                            Cursor="Hand" Click="SubmitButton_Click"/>
                    <Button x:Name="ClearButton" Content="🗑 Очистить" Width="120" Height="40" Margin="10,0,0,0"
                            Background="#6C757D" Foreground="White" Cursor="Hand" Click="ClearButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>