<Window x:Class="SZR_OperatorApp.Views.DeviationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация отклонения" Height="450" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="⚠ Регистрация отклонения" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Параметр:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
        <ComboBox x:Name="ParameterBox" Grid.Row="1" Grid.Column="1" Height="32" Margin="5" SelectedIndex="0">
            <ComboBoxItem Content="Температура"/>
            <ComboBoxItem Content="Давление"/>
            <ComboBoxItem Content="Скорость"/>
            <ComboBoxItem Content="Время выдержки"/>
            <ComboBoxItem Content="Концентрация"/>
        </ComboBox>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Плановое значение:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="PlannedValueBox" Grid.Row="2" Grid.Column="1" Height="32" Margin="5"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Факт. значение:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
        <TextBox x:Name="ActualValueBox" Grid.Row="3" Grid.Column="1" Height="32" Margin="5"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Критичность:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
        <ComboBox x:Name="SeverityBox" Grid.Row="4" Grid.Column="1" Height="32" Margin="5" SelectedIndex="0">
            <ComboBoxItem Content="Предупреждение"/>
            <ComboBoxItem Content="Критично"/>
        </ComboBox>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Описание:" FontWeight="Bold" Margin="5" VerticalAlignment="Top"/>
        <TextBox x:Name="DescriptionBox" Grid.Row="5" Grid.Column="1" Height="80" Margin="5" TextWrapping="Wrap" AcceptsReturn="True"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
            <Button x:Name="OkButton" Content="Зарегистрировать" Width="140" Height="35" 
                    Background="#28A745" Foreground="White" Cursor="Hand"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="100" Height="35" Margin="10,0,0,0"
                    Background="#6C757D" Foreground="White" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>