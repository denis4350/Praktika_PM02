<Window x:Class="SZR_OperatorApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:SZR_OperatorApp.Converters"
        Title="СЗР Производство - Модуль аппаратчика"
        Height="768"
        Width="1366"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="#F5F7FA"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <Window.Resources>

        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- MENU BUTTON -->
        <Style x:Key="MenuButton" TargetType="Button">

            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="Margin" Value="8,3"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10">

                            <ContentPresenter VerticalAlignment="Center"
                                              Margin="6,0"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#3E5871"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#22313F"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <!-- ACTION BUTTON -->
        <Style x:Key="ActionButton" TargetType="Button">

            <Setter Property="Background" Value="#2E75B6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8">

                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#1F5F99"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border"
                                        Property="Background"
                                        Value="#174B77"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <!-- DANGER BUTTON -->
        <Style x:Key="DangerButton"
               TargetType="Button"
               BasedOn="{StaticResource ActionButton}">

            <Setter Property="Background" Value="#DC3545"/>

            <Style.Triggers>

                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#B52A37"/>
                </Trigger>

            </Style.Triggers>

        </Style>

    </Window.Resources>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="42"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TOP BAR -->
        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="#2C3E50">

            <Grid Margin="20,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <Image Source="/Resources/logo.png" Width="46" Height="44" Margin="0,0,10,0"/>

                    <StackPanel VerticalAlignment="Center">

                        <TextBlock Text="СЗР Производство"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>

                        <TextBlock x:Name="CurrentSectionTitle"
                                   Text="Модуль аппаратчика"
                                   FontSize="12"
                                   Foreground="#BFC9D4"/>

                    </StackPanel>

                </StackPanel>

                <!-- RIGHT -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <!-- CONNECTION -->
                    <Border x:Name="ConnectionIndicator"
                            Background="#27AE60"
                            CornerRadius="7"
                            Width="14"
                            Height="14"
                            Margin="0,0,10,0"/>

                    <TextBlock Text="🔗"
                               FontSize="14"
                               Foreground="#BDC3C7"
                               VerticalAlignment="Center"
                               Margin="0,0,5,0"/>

                    <!-- NOTIFICATIONS BUTTON -->
                    <Button x:Name="NotificationsButton"
                            Content="🔔"
                            Width="36"
                            Height="36"
                            Background="Transparent"
                            Foreground="#BDC3C7"
                            Cursor="Hand"
                            Margin="0,0,5,0"
                            FontSize="16">

                        <Button.Template>

                            <ControlTemplate TargetType="Button">

                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="8">

                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>

                                </Border>

                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                                                Property="Background"
                                                Value="#3E5871"/>
                                    </Trigger>

                                </ControlTemplate.Triggers>

                            </ControlTemplate>

                        </Button.Template>

                    </Button>

                    <!-- USER -->
                    <TextBlock x:Name="UserInfoText"
                               Foreground="#ECF0F1"
                               FontSize="13"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="180"/>

                    <!-- SHIFT -->
                    <Border Background="#34495E"
                            CornerRadius="18"
                            Padding="14,6"
                            Margin="15,0,0,0"
                            VerticalAlignment="Center">

                        <TextBlock x:Name="ShiftText"
                                   Text="Смена 1"
                                   Foreground="#ECF0F1"
                                   FontSize="11"
                                   FontWeight="SemiBold"/>

                    </Border>

                    <!-- LOGOUT -->
                    <Button x:Name="LogoutButton"
                            Content="Выход"
                            Width="90"
                            Height="36"
                            Margin="15,0,0,0"
                            Background="#E74C3C"
                            Foreground="White"
                            Cursor="Hand"
                            BorderThickness="0"
                            FontWeight="SemiBold">

                        <Button.Template>

                            <ControlTemplate TargetType="Button">

                                <Border x:Name="border"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="8">

                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>

                                </Border>

                                <ControlTemplate.Triggers>

                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border"
                                                Property="Background"
                                                Value="#C0392B"/>
                                    </Trigger>

                                </ControlTemplate.Triggers>

                            </ControlTemplate>

                        </Button.Template>

                    </Button>

                </StackPanel>

            </Grid>

        </Border>

        <!-- LEFT MENU -->
        <Border Grid.Row="1"
                Grid.Column="0"
                Background="#2F4050"
                Padding="10,15">

            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel>

                    <Button x:Name="ActiveBatchesMenu"
                            Content="🏭  Активные партии"
                            Style="{StaticResource MenuButton}"/>

                    <Button x:Name="BatchProgramMenu"
                            Content="📋  Программа партии"
                            Style="{StaticResource MenuButton}"
                            IsEnabled="False"/>

                    <Button x:Name="ExtruderLiveMenu"
                            Content="⚡  Экструдер LIVE"
                            Style="{StaticResource MenuButton}"/>

                    <Button x:Name="JournalMenu"
                            Content="📜  Журнал партии"
                            Style="{StaticResource MenuButton}"/>

                    <Button x:Name="ReportProblemMenu"
                            Content="⚠  Сообщить о проблеме"
                            Style="{StaticResource MenuButton}"/>

                </StackPanel>

            </ScrollViewer>

        </Border>

        <!-- MAIN CONTENT -->
        <Border Grid.Row="1"
                Grid.Column="1"
                Background="White"
                CornerRadius="14"
                Margin="12"
                Padding="20">

            <ContentControl x:Name="MainContent"/>

        </Border>

        <!-- STATUS BAR -->
        <Border Grid.Row="2"
                Grid.ColumnSpan="2"
                Background="#EDF2F7">

            <Grid Margin="15,0">

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT -->
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <TextBlock Text="© 2024 Система управления производством СЗР"
                               Foreground="#718096"
                               FontSize="11"/>

                    <TextBlock Text=" | Версия 1.0"
                               Foreground="#A0AEC0"
                               FontSize="11"
                               Margin="8,0,0,0"/>

                </StackPanel>

                <!-- RIGHT -->
                <TextBlock Grid.Column="1"
                           x:Name="StatusBarText"
                           Text="● Готов"
                           Foreground="#38A169"
                           FontSize="11"
                           VerticalAlignment="Center"/>

            </Grid>

        </Border>

    </Grid>

</Window>