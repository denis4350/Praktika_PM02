<Window x:Class="SZR_OperatorApp.Views.NotificationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Уведомления" Height="400" Width="500"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="📢 Уведомления" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <ListBox x:Name="NotificationsList" Grid.Row="1">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="10" Margin="0,0,0,5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="📌" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Title}" FontWeight="Bold"/>

                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Message}" TextWrapping="Wrap" Margin="0,5,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}" 
                                       FontSize="10" Foreground="Gray" Margin="0,5,0,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button x:Name="CloseButton" Grid.Row="2" Content="Закрыть" Width="100" Height="35" 
                HorizontalAlignment="Right" Margin="0,10,0,0" Click="CloseButton_Click"/>
    </Grid>
</Window>