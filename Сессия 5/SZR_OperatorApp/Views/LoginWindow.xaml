<Window x:Class="SZR_OperatorApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация - Аппаратчик" Height="550" Width="450"
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None"
        AllowsTransparency="True" 
        Background="Transparent">

    <Grid>
        <Border Background="White" CornerRadius="15" Width="400" Height="500" 
                HorizontalAlignment="Center" VerticalAlignment="Center">
            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Кнопка закрытия -->
                <Button x:Name="CloseButton" 
                        Content="✕" 
                        Width="30" Height="30"
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top"
                        Margin="0,-10,-10,0"
                        Background="Transparent"
                        Foreground="#999"
                        BorderThickness="0"
                        FontSize="16"
                        Cursor="Hand"
                        Click="CloseButton_Click"/>

                <!-- Заголовок -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <Image x:Name="LogoImage" 
       Source="/Resources/logo.png" 
       Width="80" 
       Height="80" 
       HorizontalAlignment="Center"
       Margin="0,0,0,10"/>
                    <TextBlock Text="СЗР Производство" FontSize="20" FontWeight="Bold" 
                               Foreground="#2C3E50" TextAlignment="Center"/>
                    <TextBlock Text="Модуль аппаратчика" FontSize="14" 
                               Foreground="#7F8C8D" TextAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Выбор роли -->
                <StackPanel Grid.Row="1">
                    <TextBlock Text="Выберите роль" Foreground="#555" FontSize="12" Margin="0,0,0,5"/>
                    <ComboBox x:Name="RoleBox" Height="35" Background="#F8F9FA" 
                              BorderBrush="#D3D3D3" BorderThickness="1" Padding="10,5"
                              FontSize="13" SelectedIndex="0">
                        <ComboBoxItem Content="👷 Аппаратчик" Tag="oper.petrov"/>
                        <ComboBoxItem Content="👨‍💻 Технолог" Tag="tech.ivanov"/>
                        <ComboBoxItem Content="🔬 Лаборант" Tag="lab.sidorova"/>
                        <ComboBoxItem Content="👨‍💼 Администратор" Tag="admin"/>
                    </ComboBox>
                </StackPanel>

                <!-- Поля ввода -->
                <StackPanel Grid.Row="2" Margin="0,15,0,0">
                    <TextBlock Text="Логин" Foreground="#555" FontSize="12" Margin="0,0,0,3"/>
                    <TextBox x:Name="LoginBox" Height="35" Background="#F8F9FA" 
                             BorderBrush="#D3D3D3" BorderThickness="1" Padding="10,5"
                             FontSize="13" IsReadOnly="True"/>

                    <TextBlock Text="Пароль" Foreground="#555" FontSize="12" Margin="0,15,0,3"/>
                    <PasswordBox x:Name="PasswordBox" Height="35" Background="#F8F9FA" 
                                 BorderBrush="#D3D3D3" BorderThickness="1" Padding="10,5"
                                 FontSize="13" Password="12345"/>
                </StackPanel>

                <!-- Кнопка входа -->
                <Button x:Name="LoginButton" Grid.Row="3" Content="ВОЙТИ" 
                        Height="42" Margin="0,25,0,0"
                        Background="#2E75B6" Foreground="White" 
                        FontSize="14" FontWeight="Bold" Cursor="Hand"
                        Click="LoginButton_Click"/>

                <!-- Ошибка -->
                <TextBlock x:Name="ErrorText" Grid.Row="4" Foreground="#E74C3C" FontSize="11" 
                           TextAlignment="Center" Visibility="Collapsed" Margin="0,10,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>