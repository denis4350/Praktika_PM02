<UserControl x:Class="SZR_OperatorApp.Views.BatchProgramView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:SZR_OperatorApp.Converters">

    <UserControl.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>

        <Style x:Key="StepButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E8F0FE"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#2E75B6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="35"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E5A8A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="#28A745"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="35"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E7E34"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Шапка партии -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="🏭" FontSize="24" Margin="0,0,15,0"/>

                <StackPanel Grid.Row="0" Grid.Column="1">
                    <TextBlock x:Name="BatchNumberText" FontSize="18" FontWeight="Bold"/>
                    <TextBlock x:Name="ProductNameText" FontSize="12" Foreground="#666"/>
                </StackPanel>

                <Border Grid.Row="0" Grid.Column="2" CornerRadius="10" Padding="10,3" Background="{Binding BatchStatusColor}">
                    <TextBlock x:Name="StatusText" FontSize="11" Foreground="White"/>
                </Border>

                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Линия:" FontSize="12" Foreground="#666" Margin="0,0,5,0"/>
                    <TextBlock x:Name="LineText" FontSize="12" FontWeight="SemiBold" Margin="0,0,15,0"/>

                    <TextBlock Text="Текущий шаг:" FontSize="12" Foreground="#666" Margin="0,0,5,0"/>
                    <TextBlock x:Name="CurrentStepText" FontSize="12" FontWeight="SemiBold" Margin="0,0,15,0"/>

                    <TextBlock Text="Время начала:" FontSize="12" Foreground="#666" Margin="0,0,5,0"/>
                    <TextBlock x:Name="StartedAtText" FontSize="12" Foreground="#666"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основная область: список шагов слева, рабочая зона справа -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Список шагов -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="10" Margin="0,0,15,0" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="📋 Технологические шаги" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="500">
                        <ItemsControl x:Name="StepsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button x:Name="StepButton" Style="{StaticResource StepButton}" Tag="{Binding}" Click="StepButton_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="30"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="auto"/>
                                                <ColumnDefinition Width="auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0" Text="{Binding StepNumber}" FontWeight="Bold"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="10,0,0,0"/>

                                            <Border Grid.Column="2" Width="8" Height="8" CornerRadius="4" 
                                                    Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}"
                                                    Margin="10,0,5,0"/>

                                            <TextBlock Grid.Column="3" Text="{Binding Status}" FontSize="11" Foreground="#666"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- Рабочая зона шага -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" BorderBrush="#E0E0E0" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок шага -->
                    <TextBlock x:Name="StepTitleText" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <!-- Инструкция -->
                    <Border Grid.Row="1" Background="#F0F8FF" CornerRadius="6" Padding="10" Margin="0,0,0,15">
                        <TextBlock x:Name="InstructionText" TextWrapping="Wrap" FontSize="12"/>
                    </Border>

                    <!-- Параметры -->
                    <TextBlock Grid.Row="2" Text="📊 Параметры выполнения" FontSize="13" FontWeight="Bold" Margin="0,0,0,10"/>

                    <Grid Grid.Row="3" Margin="0,0,0,15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Температура:" FontWeight="SemiBold" Margin="5"/>
                        <TextBox x:Name="TemperatureBox" Grid.Row="0" Grid.Column="1" Height="32" Margin="5" Width="150" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Давление:" FontWeight="SemiBold" Margin="5"/>
                        <TextBox x:Name="PressureBox" Grid.Row="1" Grid.Column="1" Height="32" Margin="5" Width="150" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Скорость:" FontWeight="SemiBold" Margin="5"/>
                        <TextBox x:Name="SpeedBox" Grid.Row="2" Grid.Column="1" Height="32" Margin="5" Width="150" HorizontalAlignment="Left"/>
                    </Grid>

                    <!-- Допустимые диапазоны -->
                    <TextBlock x:Name="ToleranceText" Grid.Row="4" FontSize="11" Foreground="#666" TextWrapping="Wrap"/>

                    <!-- Кнопки действий -->
                    <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                        <Button x:Name="StartStepButton" Content="▶ Начать шаг" Width="120" Style="{StaticResource SuccessButton}"
                                Visibility="Collapsed" Click="StartStepButton_Click"/>
                        <Button x:Name="CompleteStepButton" Content="⏹ Завершить шаг" Width="130" Style="{StaticResource ActionButton}"
                                Visibility="Collapsed" Click="CompleteStepButton_Click"/>
                        <Button x:Name="ReportDeviationButton" Content="⚠ Сообщить об отклонении" Width="170" 
                                Style="{StaticResource ActionButton}" Click="ReportDeviationButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>