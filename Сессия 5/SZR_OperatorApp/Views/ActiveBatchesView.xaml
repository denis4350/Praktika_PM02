<UserControl x:Class="SZR_OperatorApp.Views.ActiveBatchesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:SZR_OperatorApp.Converters">

    <UserControl.Resources>
        <converters:SeverityToColorConverter x:Key="SeverityToColorConverter"/>

        <DataTemplate x:Key="BatchCardTemplate">
            <Border Background="White" CornerRadius="8" Padding="12" Margin="8"
                    BorderBrush="#E0E0E0" BorderThickness="1" Cursor="Hand"
                    MouseLeftButtonUp="BatchCard_Click">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Номер партии и статус партии -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding BatchNumber}" FontSize="16" FontWeight="Bold"/>
                    <Border Grid.Row="0" Grid.Column="1" CornerRadius="10" Padding="8,2" Background="{Binding StatusColor}">
                        <TextBlock Text="{Binding BatchStatus}" FontSize="10" Foreground="White"/>
                    </Border>

                    <!-- Продукт и линия -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding ProductName}" FontSize="12" Foreground="#666" Margin="0,5,0,0"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Line}" FontSize="12" Foreground="#666"/>

                    <!-- Текущий шаг и статус шага -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding CurrentStepName}" FontSize="11" Foreground="#888" Margin="0,5,0,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding StepStatus}" FontSize="10" Foreground="#666" Margin="10,5,0,0" HorizontalAlignment="Right"/>

                    <!-- Индикаторы проблем -->
                    <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <Border x:Name="WarningIndicator" CornerRadius="10" Width="8" Height="8" 
                                Background="Orange" Margin="0,0,5,0"
                                Visibility="{Binding HasWarning, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <Border x:Name="CriticalIndicator" CornerRadius="10" Width="8" Height="8" 
                                Background="Red" Margin="0,0,5,0"
                                Visibility="{Binding HasCriticalDeviation, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Панель фильтров -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="12" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="SearchBox" Grid.Column="0" Height="32" Margin="0,0,10,0"
                         Background="#F8F9FA" BorderBrush="#D3D3D3" BorderThickness="1"
                         Padding="10,5" TextChanged="SearchBox_TextChanged"/>

                <ComboBox x:Name="LineFilterBox" Grid.Column="1" Width="100" Height="32" Margin="0,0,10,0"
                          SelectionChanged="Filter_SelectionChanged">
                    <ComboBoxItem Content="Все линии"/>
                    <ComboBoxItem Content="L-01"/>
                    <ComboBoxItem Content="L-02"/>
                    <ComboBoxItem Content="L-03"/>
                </ComboBox>

                <ComboBox x:Name="StatusFilterBox" Grid.Column="2" Width="120" Height="32" Margin="0,0,10,0"
                          SelectionChanged="Filter_SelectionChanged">
                    <ComboBoxItem Content="Все статусы"/>
                    <ComboBoxItem Content="В работе"/>
                    <ComboBoxItem Content="Подготовлена"/>
                    <ComboBoxItem Content="Ожидает контроля"/>
                </ComboBox>

                <ComboBox x:Name="ProductFilterBox" Grid.Column="3" Width="150" Height="32" Margin="0,0,10,0"
                          SelectionChanged="Filter_SelectionChanged">
                    <ComboBoxItem Content="Все продукты"/>
                </ComboBox>

                <Button x:Name="RefreshButton" Grid.Column="4" Content="🔄 Обновить" Width="100" Height="32"
                        Background="#2E75B6" Foreground="White" Cursor="Hand" Click="RefreshButton_Click"/>
            </Grid>
        </Border>

        <!-- Список активных партий -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="BatchesItemsControl" ItemTemplate="{StaticResource BatchCardTemplate}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock x:Name="StatusTextBlock" Text="" Foreground="Gray" 
                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                   Visibility="Collapsed" Margin="0,20,0,0"/>
    </Grid>
</UserControl>