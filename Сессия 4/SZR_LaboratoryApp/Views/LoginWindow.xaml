<Window x:Class="SZR_LaboratoryApp.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация - Лаборатория" Height="600" Width="450"
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None"
        AllowsTransparency="True" 
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="TabHeaderStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="LoginButton" TargetType="Button">
            <Setter Property="Background" Value="#2E75B6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E5A8A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RegisterButton" TargetType="Button">
            <Setter Property="Background" Value="#28A745"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E7E34"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RefreshButton" TargetType="Button">
            <Setter Property="Background" Value="#34495E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="45"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2C3E50"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputField" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#D3D3D3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="PasswordField" TargetType="PasswordBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#D3D3D3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="ComboBoxField" TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#D3D3D3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="White" CornerRadius="15" Width="420" Height="570" 
                HorizontalAlignment="Center" VerticalAlignment="Center">

            <Grid>
                <!-- Кнопка закрытия -->
                <Button x:Name="CloseButton" 
                        Content="✕" 
                        Width="30" Height="30"
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top"
                        Margin="0,10,10,0"
                        Background="Transparent"
                        Foreground="#999"
                        BorderThickness="0"
                        FontSize="16"
                        Cursor="Hand"
                        Click="CloseButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#E74C3C"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Grid Margin="25,10,25,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <Image x:Name="LogoImage" 
                               Source="/Resources/logo.png" 
                               Width="80" 
                               Height="80" 
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>

                        <TextBlock Text="СЗР Производство" FontSize="22" FontWeight="Bold" 
                                   Foreground="#2C3E50" TextAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBlock Text="Лабораторный модуль" FontSize="12" 
                                   Foreground="#7F8C8D" TextAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Переключатель вкладок -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="LoginTabPanel" Grid.Column="0" Style="{StaticResource TabHeaderStyle}" MouseLeftButtonUp="LoginTab_Click" Grid.ColumnSpan="2" Margin="86,0,99,0">
                            <TextBlock x:Name="LoginTabText" Text="🔐 Вход" FontSize="14" FontWeight="Bold" 
                                       HorizontalAlignment="Center" Foreground="#2E75B6"/>
                        </Border>

                    </Grid>

                    <!-- Разделитель -->
                    <Border Grid.Row="2" Height="2" Background="#EEF2F7" Margin="0,0,0,15"/>

                    <!-- ПАНЕЛЬ ВХОДА -->
                    <StackPanel x:Name="LoginPanel" Grid.Row="3">
                        <TextBlock Text="Логин" Foreground="#555" FontSize="12" Margin="0,0,0,3"/>
                        <TextBox x:Name="LoginBox" Style="{StaticResource InputField}" Text="lab.sidorova"/>

                        <TextBlock Text="Пароль" Foreground="#555" FontSize="12" Margin="0,12,0,3"/>
                        <PasswordBox x:Name="PasswordBox" Style="{StaticResource PasswordField}" Password="12345"/>

                        <TextBlock Text="Введите код с картинки" Foreground="#555" FontSize="12" Margin="0,15,0,5"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <Image x:Name="CaptchaImage" Grid.Column="0" Height="55" Stretch="Uniform"/>
                            <Button x:Name="RefreshCaptchaButton" Grid.Column="1" Content="🔄" 
                                    Width="45" Height="45" Margin="10,0,0,0" Style="{StaticResource RefreshButton}"/>
                        </Grid>
                        <TextBox x:Name="CaptchaInputBox" Style="{StaticResource InputField}" Margin="0,0,0,10"/>

                        <Button x:Name="LoginButton" Content="ВОЙТИ" Style="{StaticResource LoginButton}" Margin="0,15,0,0"/>
                    </StackPanel>

                    <!-- ПАНЕЛЬ РЕГИСТРАЦИИ -->
                    <StackPanel x:Name="RegisterPanel" Grid.Row="3" Visibility="Collapsed">
                        <TextBlock Text="Логин" Foreground="#555" FontSize="12" Margin="0,0,0,3"/>
                        <TextBox x:Name="RegisterLoginBox" Style="{StaticResource InputField}"/>

                        <TextBlock Text="Пароль" Foreground="#555" FontSize="12" Margin="0,12,0,3"/>
                        <PasswordBox x:Name="RegisterPasswordBox" Style="{StaticResource PasswordField}"/>

                        <TextBlock Text="ФИО" Foreground="#555" FontSize="12" Margin="0,12,0,3"/>
                        <TextBox x:Name="RegisterFullNameBox" Style="{StaticResource InputField}"/>

                        <TextBlock Text="Отдел/подразделение" Foreground="#555" FontSize="12" Margin="0,12,0,3"/>
                        <ComboBox x:Name="RegisterDepartmentComboBox" Style="{StaticResource ComboBoxField}" 
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Лаборатория"/>
                            <ComboBoxItem Content="Технологический отдел"/>
                            <ComboBoxItem Content="Цех №1"/>
                            <ComboBoxItem Content="Цех №2"/>
                            <ComboBoxItem Content="ИТ отдел"/>
                            <ComboBoxItem Content="Отдел качества"/>
                        </ComboBox>

                        <TextBlock Text="Введите код с картинки" Foreground="#555" FontSize="12" Margin="0,15,0,5"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <Image x:Name="RegCaptchaImage" Grid.Column="0" Height="55" Stretch="Uniform"/>
                            <Button x:Name="RefreshRegCaptchaButton" Grid.Column="1" Content="🔄" 
                                    Width="45" Height="45" Margin="10,0,0,0" Style="{StaticResource RefreshButton}"/>
                        </Grid>
                        <TextBox x:Name="RegCaptchaInputBox" Style="{StaticResource InputField}" Margin="0,0,0,5"/>

                        <Button x:Name="RegisterButton" Content="ЗАРЕГИСТРИРОВАТЬСЯ" Style="{StaticResource RegisterButton}" Margin="0,15,0,0"/>
                    </StackPanel>

                    <!-- Ошибка -->
                    <TextBlock x:Name="ErrorText" Foreground="#E74C3C" FontSize="11" 
                               TextAlignment="Center" Visibility="Collapsed" Margin="0,10,0,0"
                               VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>