<Window x:Class="SZR_LaboratoryApp.Views.RawMaterialCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:SZR_LaboratoryApp.Converters"
        Title="Карточка партии сырья" Height="700" Width="900"
        WindowStartupLocation="CenterOwner" WindowStyle="SingleBorderWindow">

    <Window.Resources>
        <converters:StatusToColorConverter x:Key="StatusToColorConverter"/>
        <converters:BoolToYesNoConverter x:Key="BoolToYesNoConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2C3E50" CornerRadius="8" Padding="15" Margin="0,0,0,15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📦" FontSize="24" Margin="0,0,10,0"/>
                <TextBlock Text="Карточка партии сырья" FontSize="18" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="StatusBadge" Text="" FontSize="12" Margin="15,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Основная информация -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="№ партии:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
                <TextBlock x:Name="BatchNumberText" Grid.Row="0" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="0" Grid.Column="2" Text="№ поставщика:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
                <TextBlock x:Name="SupplierBatchText" Grid.Row="0" Grid.Column="3" Margin="5" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Материал:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
                <TextBlock x:Name="MaterialNameText" Grid.Row="1" Grid.Column="1" Margin="5" VerticalAlignment="Center" FontWeight="Bold"/>

                <TextBlock Grid.Row="1" Grid.Column="2" Text="Категория:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
                <TextBlock x:Name="CategoryText" Grid.Row="1" Grid.Column="3" Margin="5" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Поставщик:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
                <TextBlock x:Name="SupplierText" Grid.Row="2" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2" Grid.Column="2" Text="Дата поступления:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
                <TextBlock x:Name="ArrivalDateText" Grid.Row="2" Grid.Column="3" Margin="5" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="3" Grid.Column="0" Text="Количество:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
                <TextBlock x:Name="QuantityText" Grid.Row="3" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="3" Grid.Column="2" Text="Статус:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
                <TextBlock x:Name="LabStatusText" Grid.Row="3" Grid.Column="3" Margin="5" VerticalAlignment="Center" FontWeight="Bold"/>
            </Grid>
        </Border>

        <!-- Вкладки -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="TestsTab" Grid.Column="0" Background="#E8F0FE" Padding="10" Cursor="Hand" MouseLeftButtonUp="TestsTab_Click">
                <TextBlock x:Name="TestsTabText" Text="📋 Испытания" HorizontalAlignment="Center" FontWeight="Bold"/>
            </Border>

            <Border x:Name="HistoryTab" Grid.Column="1" Background="Transparent" Padding="10" Cursor="Hand" MouseLeftButtonUp="HistoryTab_Click">
                <TextBlock x:Name="HistoryTabText" Text="📜 История изменений" HorizontalAlignment="Center"/>
            </Border>

            <Border x:Name="DecisionTab" Grid.Column="2" Background="Transparent" Padding="10" Cursor="Hand" MouseLeftButtonUp="DecisionTab_Click">
                <TextBlock x:Name="DecisionTabText" Text="🔬 Решение" HorizontalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- Разделитель -->
        <Border Grid.Row="3" Height="2" Background="#EEF2F7" Margin="0,5,0,10"/>

        <!-- Содержимое вкладок -->
        <Grid Grid.Row="4">
            <!-- Испытания -->
            <DataGrid x:Name="TestsGrid" AutoGenerateColumns="False" SelectionMode="Single" Visibility="Visible">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№ испытания" Binding="{Binding testNumber}" Width="100"/>
                    <DataGridTextColumn Header="Тип" Binding="{Binding testType}" Width="100"/>
                    <DataGridTextColumn Header="Дата" Binding="{Binding assignedAt, StringFormat='dd.MM.yyyy'}" Width="100"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding status}" Width="100"/>
                    <DataGridTextColumn Header="Результат" Binding="{Binding Result}" Width="100"/>
                    <DataGridTemplateColumn Header="Действия" Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Подробнее" Click="ViewTest_Click" Tag="{Binding}" 
                                        Background="#2E75B6" Foreground="White" Padding="8,4" BorderThickness="0" Cursor="Hand"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- История изменений -->
            <DataGrid x:Name="HistoryGrid" AutoGenerateColumns="False" Visibility="Collapsed">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Дата" Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}" Width="140"/>
                    <DataGridTextColumn Header="Пользователь" Binding="{Binding UserName}" Width="150"/>
                    <DataGridTextColumn Header="Действие" Binding="{Binding Action}" Width="200"/>
                    <DataGridTextColumn Header="Было" Binding="{Binding OldValue}" Width="100"/>
                    <DataGridTextColumn Header="Стало" Binding="{Binding NewValue}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Панель решения -->
            <Border x:Name="DecisionPanel" Visibility="Collapsed" Background="#FFF8E1" CornerRadius="8" Padding="15" BorderBrush="#FFE082" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="🔬 Лабораторное решение" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Текущий статус:" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="CurrentStatusText" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" FontWeight="Bold"/>

                    <TextBlock x:Name="DecisionInfoLabel" Grid.Row="2" Grid.Column="0" Text="Решение принял:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,10,0,0"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,10,0,0">
                        <TextBlock x:Name="DecisionByText" FontWeight="SemiBold"/>
                        <TextBlock x:Name="DecisionAtText" FontSize="11" Foreground="Gray"/>
                        <TextBlock x:Name="DecisionCommentText" FontSize="11" Foreground="Gray" TextWrapping="Wrap"/>
                    </StackPanel>

                    <Separator x:Name="DecisionSeparator" Grid.Row="3" Grid.ColumnSpan="2" Margin="0,10" Visibility="Collapsed"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Решение:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,10,0,0"/>
                    <ComboBox x:Name="DecisionComboBox" Grid.Row="4" Grid.Column="1" Height="32" Margin="0,10,0,0" SelectedIndex="0">
                        <ComboBoxItem Content="Разрешена"/>
                        <ComboBoxItem Content="Заблокирована"/>
                    </ComboBox>

                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Комментарий:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,10,0,0"/>
                    <TextBox x:Name="DecisionCommentBox" Grid.Row="5" Grid.Column="1" Height="50" Margin="0,10,0,0" TextWrapping="Wrap" AcceptsReturn="True"/>

                    <Button x:Name="ApplyDecisionButton" Grid.Row="6" Grid.ColumnSpan="2" Content="✅ Применить решение" 
                            Width="150" Height="35" HorizontalAlignment="Center" Margin="0,15,0,0"
                            Background="#28A745" Foreground="White" Click="ApplyDecisionButton_Click" Cursor="Hand"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Индикатор загрузки -->
        <TextBlock x:Name="LoadingHistory" Grid.Row="4" Text="Загрузка истории..." 
                   HorizontalAlignment="Center" VerticalAlignment="Center" 
                   Visibility="Collapsed" FontStyle="Italic" Foreground="Gray"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="NewTestButton" Content="➕ Новое испытание" Width="148" Height="35" 
                    Background="#28A745" Foreground="White" Click="NewTestButton_Click" Cursor="Hand"/>
            <Button x:Name="CloseButton" Content="✖ Закрыть" Width="100" Height="35" 
                    Background="#6C757D" Foreground="White" Click="CloseButton_Click" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>