<Window x:Class="SZR_TechnologistApp.Views.ProductForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Продукт" Height="480" Width="500"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Код:" FontWeight="Bold" Margin="5"/>
        <TextBox x:Name="CodeBox" Grid.Row="0" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Наименование:" FontWeight="Bold" Margin="5"/>
        <TextBox x:Name="NameBox" Grid.Row="1" Grid.Column="1" Margin="5" Height="30"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Тип:" FontWeight="Bold" Margin="5"/>
        <ComboBox x:Name="TypeBox" Grid.Row="2" Grid.Column="1" Margin="5" Height="30">
            <ComboBoxItem Content="Гранулы"/>
            <ComboBoxItem Content="Жидкость"/>
            <ComboBoxItem Content="Порошок"/>
        </ComboBox>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Форма:" FontWeight="Bold" Margin="5"/>
        <ComboBox x:Name="FormBox" Grid.Row="3" Grid.Column="1" Margin="5" Height="30">
            <ComboBoxItem Content="Сухая"/>
            <ComboBoxItem Content="Жидкая"/>
            <ComboBoxItem Content="Паста"/>
        </ComboBox>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Статус:" FontWeight="Bold" Margin="5"/>
        <ComboBox x:Name="StatusBox" Grid.Row="4" Grid.Column="1" Margin="5" Height="30">
            <ComboBoxItem Content="Активен"/>
            <ComboBoxItem Content="Архивирован"/>
        </ComboBox>

        <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="SaveButton" Content="Сохранить" Width="100" Height="35" 
                    Background="#28A745" Foreground="White" Margin="10"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="100" Height="35" 
                    Background="#6C757D" Foreground="White" Margin="10" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>