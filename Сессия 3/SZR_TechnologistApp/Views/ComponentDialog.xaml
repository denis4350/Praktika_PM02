<Window x:Class="SZR_TechnologistApp.Views.ComponentDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление компонента"
        Height="640"
        Width="560"
        MinHeight="520"
        MinWidth="540"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EEF2F7"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#0F172A"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
        <SolidColorBrush x:Key="SuccessDarkBrush" Color="#15803D"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#DDE3EC"/>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="22"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#9AA8BA"
                                      BlurRadius="16"
                                      ShadowDepth="2"
                                      Opacity="0.16"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="120"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SuccessDarkBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CBD5E1"/>
                    <Setter Property="Foreground" Value="#64748B"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#475569"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#334155"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CBD5E1"/>
                    <Setter Property="Foreground" Value="#64748B"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Border Style="{StaticResource CardBorder}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="18"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Добавление компонента"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="{StaticResource PrimaryTextBrush}"/>
                    <TextBlock Text="Выберите сырьё, укажите процентную долю, допуски и порядок загрузки."
                               FontSize="13"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Компонент -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="Компонент" Style="{StaticResource LabelText}"/>
                    <ComboBox x:Name="MaterialComboBox"
                              DisplayMemberPath="Name"
                              SelectedValuePath="Id"/>
                </StackPanel>

                <!-- Доля -->
                <StackPanel Grid.Row="4">
                    <TextBlock Text="Доля, %" Style="{StaticResource LabelText}"/>
                    <TextBox x:Name="PercentageBox"
                             Text=""/>
                </StackPanel>

                <!-- Допуски -->
                <Grid Grid.Row="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Допуск минимум" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="ToleranceMinBox"
                                 Text=""/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Допуск максимум" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="ToleranceMaxBox"
                                 Text=""/>
                    </StackPanel>
                </Grid>

                <!-- Порядок -->
                <StackPanel Grid.Row="8">
                    <TextBlock Text="Порядок загрузки" Style="{StaticResource LabelText}"/>
                    <TextBox x:Name="LoadOrderBox"
                             Text="1"/>
                </StackPanel>

                <!-- Информация -->
                <Border Grid.Row="10"
                        Background="#FFFBEB"
                        BorderBrush="#FDE68A"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10">
                    <TextBlock Text="Сумма долей всех компонентов рецептуры должна составлять 100%."
                               Foreground="#92400E"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Ошибка -->
                <Border x:Name="ErrorPanel"
                        Grid.Row="11"
                        Background="#FEF2F2"
                        BorderBrush="#FECACA"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10"
                        Margin="0,14,0,0"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText"
                               Foreground="{StaticResource DangerBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- Кнопки -->
                <StackPanel Grid.Row="13"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,22,0,0">
                    <Button x:Name="CancelButton"
                            Content="Отмена"
                            Style="{StaticResource SecondaryButton}"
                            Click="CancelButton_Click"/>

                    <Button x:Name="OkButton"
                            Content="Добавить"
                            Style="{StaticResource PrimaryButton}"
                            Click="OkButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>