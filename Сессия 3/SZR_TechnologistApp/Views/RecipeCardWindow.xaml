<Window x:Class="SZR_TechnologistApp.Views.RecipeCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Карточка рецептуры"
        Height="720"
        Width="980"
        MinHeight="680"
        MinWidth="920"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        Background="#EEF2F7"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
        <SolidColorBrush x:Key="SuccessDarkBrush" Color="#15803D"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#DC2626"/>
        <SolidColorBrush x:Key="DangerDarkBrush" Color="#B91C1C"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#DDE3EC"/>

        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#9AA8BA"
                                      BlurRadius="14"
                                      ShadowDepth="2"
                                      Opacity="0.14"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CBD5E1"/>
                    <Setter Property="Foreground" Value="#64748B"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource SuccessDarkBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CBD5E1"/>
                    <Setter Property="Foreground" Value="#64748B"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource DangerBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource DangerDarkBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CBD5E1"/>
                    <Setter Property="Foreground" Value="#64748B"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#475569"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="112"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#334155"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TabBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="11"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="TabTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AlternatingRowBackground" Value="#F8FAFC"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E2E8F0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="ColumnHeaderHeight" Value="40"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0"
                CornerRadius="18"
                Padding="22"
                Margin="0,0,0,16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0F172A" Offset="0"/>
                    <GradientStop Color="#1E3A8A" Offset="0.58"/>
                    <GradientStop Color="#2563EB" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Карточка рецептуры"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock x:Name="HeaderSubtitleText"
                               Text="Состав рецептуры и связанные технологические карты"
                               FontSize="13"
                               Foreground="#C7D2FE"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="#1E293B"
                        CornerRadius="12"
                        Padding="14,8"
                        Opacity="0.92"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Статус"
                                   FontSize="11"
                                   Foreground="#CBD5E1"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="StatusBadge"
                                   Text="—"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Информация о рецептуре -->
        <Border Grid.Row="1"
                Style="{StaticResource CardBorder}"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="0.6*"/>
                    <ColumnDefinition Width="1.8*"/>
                    <ColumnDefinition Width="0.8*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1.1*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,18,0">
                    <TextBlock Text="ID" Style="{StaticResource LabelText}"/>
                    <TextBlock x:Name="IdText" Style="{StaticResource ValueText}"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="0,0,18,0">
                    <TextBlock Text="Продукт" Style="{StaticResource LabelText}"/>
                    <TextBlock x:Name="ProductNameText"
                               Style="{StaticResource ValueText}"
                               FontSize="15"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Margin="0,0,18,0">
                    <TextBlock Text="Версия" Style="{StaticResource LabelText}"/>
                    <TextBlock x:Name="VersionText" Style="{StaticResource ValueText}"/>
                </StackPanel>

                <StackPanel Grid.Column="3" Margin="0,0,18,0">
                    <TextBlock Text="Статус" Style="{StaticResource LabelText}"/>
                    <Border x:Name="StatusPanel"
                            Background="#E2E8F0"
                            CornerRadius="10"
                            Padding="10,4"
                            HorizontalAlignment="Left">
                        <TextBlock x:Name="StatusText"
                                   Text="—"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Foreground="#475569"/>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="4">
                    <TextBlock Text="Дата создания" Style="{StaticResource LabelText}"/>
                    <TextBlock x:Name="CreatedAtText"
                               Style="{StaticResource ValueText}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Вкладки -->
        <Border Grid.Row="2"
                Background="#F1F5F9"
                CornerRadius="14"
                Padding="4"
                Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="ComponentsTab"
                        Grid.Column="0"
                        Style="{StaticResource TabBorderStyle}"
                        MouseLeftButtonUp="ComponentsTab_Click">
                    <TextBlock x:Name="ComponentsTabText"
                               Text="Компоненты"
                               Style="{StaticResource TabTextStyle}"/>
                </Border>

                <Border x:Name="TechCardsTab"
                        Grid.Column="1"
                        Style="{StaticResource TabBorderStyle}"
                        MouseLeftButtonUp="TechCardsTab_Click">
                    <TextBlock x:Name="TechCardsTabText"
                               Text="Связанные техкарты"
                               Style="{StaticResource TabTextStyle}"/>
                </Border>
            </Grid>
        </Border>

        <!-- Содержимое вкладок -->
        <Border Grid.Row="3"
                Style="{StaticResource CardBorder}"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="#F8FAFC"
                        CornerRadius="16,16,0,0"
                        Padding="16,14"
                        BorderBrush="#E2E8F0"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <StackPanel>
                            <TextBlock x:Name="TabTitleText"
                                       Text="Компоненты рецептуры"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="#0F172A"/>
                            <TextBlock x:Name="TabSubtitleText"
                                       Text="Сырьё, доли, допустимые отклонения и порядок загрузки"
                                       FontSize="12"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <TextBlock x:Name="ItemsCountText"
                                   Text="0 записей"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource MutedTextBrush}"/>
                    </Grid>
                </Border>

                <!-- Компоненты -->
                <DataGrid x:Name="ComponentsGrid"
                          Grid.Row="1"
                          SelectionMode="Single"
                          Visibility="Visible">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                        <DataGridTextColumn Header="Компонент" Binding="{Binding RawMaterialName}" Width="240"/>
                        <DataGridTextColumn Header="Доля, %" Binding="{Binding Percentage}" Width="110"/>
                        <DataGridTextColumn Header="Допуск мин" Binding="{Binding ToleranceMin}" Width="120"/>
                        <DataGridTextColumn Header="Допуск макс" Binding="{Binding ToleranceMax}" Width="120"/>
                        <DataGridTextColumn Header="Порядок" Binding="{Binding LoadOrder}" Width="100"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Связанные техкарты -->
                <DataGrid x:Name="TechCardsGrid"
                          Grid.Row="1"
                          SelectionMode="Single"
                          Visibility="Collapsed">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="70"/>
                        <DataGridTextColumn Header="Версия" Binding="{Binding Version}" Width="120"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="160"/>
                        <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy'}" Width="160"/>
                        <DataGridTextColumn Header="Утверждена" Binding="{Binding ApprovedAt, StringFormat='dd.MM.yyyy'}" Width="160"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Ошибка -->
                <Border x:Name="ErrorPanel"
                        Grid.Row="2"
                        Background="#FEF2F2"
                        BorderBrush="#FECACA"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="10"
                        Margin="14"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText"
                               Foreground="{StaticResource DangerBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </Border>
            </Grid>
        </Border>

        <!-- Кнопки -->
        <Border Grid.Row="4"
                Background="#E2E8F0"
                CornerRadius="10"
                Padding="12"
                Margin="0,14,0,0">
            <Grid>
                <TextBlock x:Name="FooterText"
                           Text="Просмотр рецептуры"
                           Foreground="#475569"
                           FontSize="12"
                           VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button x:Name="ApproveButton"
                            Content="Утвердить"
                            Style="{StaticResource SuccessButton}"
                            Visibility="Collapsed"
                            Click="ApproveButton_Click"/>

                    <Button x:Name="ArchiveButton"
                            Content="Архивировать"
                            Style="{StaticResource DangerButton}"
                            Visibility="Collapsed"
                            Click="ArchiveButton_Click"/>

                    <Button x:Name="RefreshButton"
                            Content="Обновить"
                            Style="{StaticResource PrimaryButton}"
                            Click="RefreshButton_Click"/>

                    <Button x:Name="CloseButton"
                            Content="Закрыть"
                            Style="{StaticResource SecondaryButton}"
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>