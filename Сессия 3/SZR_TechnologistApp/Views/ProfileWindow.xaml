<Window x:Class="SZR_TechnologistApp.Views.ProfileWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="👤 Мой профиль"
        Height="450"
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#EEF2F7">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Width="80" Height="80" CornerRadius="40" 
                ClipToBounds="True" Background="#1ABC9C" HorizontalAlignment="Center" Margin="0,0,0,15"
                Cursor="Hand" MouseLeftButtonUp="ChangeAvatar_Click">
            <Grid>
                <Image x:Name="AvatarImage" Stretch="UniformToFill"/>
                <TextBlock x:Name="InitialsText" FontSize="32" FontWeight="Bold" Foreground="White" 
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <Border Background="#66000000" CornerRadius="40" VerticalAlignment="Bottom" Height="25">
                    <TextBlock Text="📷" Foreground="White" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </Grid>
        </Border>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="ФИО:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
        <TextBlock x:Name="FullNameText" Grid.Row="1" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Логин:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
        <TextBlock x:Name="LoginText" Grid.Row="2" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Роль:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
        <TextBlock x:Name="RoleText" Grid.Row="3" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Отдел:" FontWeight="Bold" Margin="5" VerticalAlignment="Center"/>
        <TextBlock x:Name="DepartmentText" Grid.Row="4" Grid.Column="1" Margin="5" VerticalAlignment="Center"/>

        <Button x:Name="CloseButton" Grid.Row="5" Grid.ColumnSpan="2" Content="Закрыть" Width="100" Height="35" 
                HorizontalAlignment="Center" Margin="0,20,0,0" Background="#2E75B6" Foreground="White" Cursor="Hand"/>
    </Grid>
</Window>